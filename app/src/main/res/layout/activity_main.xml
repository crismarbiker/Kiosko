<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- WebView principal (oculto hasta que se configure la URL) -->
    <com.mamvid.kiosko.webview.KioskoWebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Contenedor de popup (window.open) -->
    <FrameLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:visibility="gone" />

    <!-- Barra de progreso de carga (borde superior) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="@color/colorPrimary"
        android:progressBackgroundTint="@android:color/transparent"
        android:visibility="gone" />

    <!-- Pantalla de error / sin conexión (oculta por defecto) -->
    <LinearLayout
        android:id="@+id/errorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="#FFFFFF"
        android:visibility="gone">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_wifi_off"
            android:alpha="0.5"
            android:contentDescription="Sin conexión" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sin conexión"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground" />

        <TextView
            android:id="@+id/tvReconnecting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Reconectando..."
            android:textSize="15sp"
            android:textColor="@color/colorOnBackgroundSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Reintentar"
            android:paddingHorizontal="32dp"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════
         Pantalla de configuración inicial
         Visible cuando no hay URL configurada
         ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/setupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:padding="32dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/logo_app"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:src="@drawable/logo_company"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="MamVid"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Bienvenido a Kiosko!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:gravity="center"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure el sitio web para comenzar"
            android:textSize="15sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToConfig"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Configurar Aplicación"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginTop="36dp" />

    </LinearLayout>

    <!-- Zona oculta de acceso al panel admin
         5 taps rápidos o mantener 3 segundos — esquina inferior izquierda
         elevation="8dp" garantiza recibir los toques sobre cualquier vista -->
    <View
        android:id="@+id/adminTriggerArea"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="bottom|start"
        android:background="@android:color/transparent"
        android:elevation="8dp" />

</FrameLayout>
