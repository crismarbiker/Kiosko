<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Main WebView -->
    <com.mamvid.kiosko.webview.KioskoWebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Popup WebView overlay (for window.open popups) -->
    <FrameLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground"
        android:elevation="8dp"
        android:visibility="gone" />

    <!-- Page loading progress bar (top edge) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="@color/colorPrimary"
        android:progressBackgroundTint="@android:color/transparent"
        android:visibility="gone" />

    <!-- Error / Reconnecting overlay -->
    <LinearLayout
        android:id="@+id/errorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="@color/colorBackground"
        android:visibility="gone">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_wifi_off"
            android:alpha="0.6"
            android:contentDescription="Sin conexión" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sin conexión"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground" />

        <TextView
            android:id="@+id/tvReconnecting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Reconectando..."
            android:textSize="15sp"
            android:textColor="@color/colorOnBackgroundSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Reintentar"
            android:paddingHorizontal="32dp"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- Hidden tap area for admin access — bottom-left corner, fully transparent -->
    <View
        android:id="@+id/adminTriggerArea"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="0dp"
        android:background="@android:color/transparent" />

</FrameLayout>
